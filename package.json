{
  "name": "pi-loom",
  "version": "0.0.1",
  "description": "Dynamic multi-agent workflow orchestration for the pi agent harness — a faithful clone of Claude Code's workflow primitives (agent/parallel/pipeline/phase/log/budget) with structured output, adversarial verification, resumable journaling, and a live progress UI (terminal + web). Ships a pi extension that registers a run_workflow tool.",
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./web": {
      "types": "./dist/web.d.ts",
      "import": "./dist/web.js"
    }
  },
  "pi": {
    "extensions": ["extensions/workflow.ts"]
  },
  "files": [
    "dist",
    "extensions",
    "src",
    "!src/**/*.test.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "pi-loom",
    "agent",
    "workflow",
    "orchestration",
    "multi-agent",
    "pi",
    "llm"
  ],
  "license": "MIT",
  "author": "betaHi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/betaHi/pi-loom.git"
  },
  "homepage": "https://github.com/betaHi/pi-loom#readme",
  "bugs": {
    "url": "https://github.com/betaHi/pi-loom/issues"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.79.4",
    "@earendil-works/pi-ai": "0.79.4",
    "acorn": "^8.12.0"
  },
  "optionalDependencies": {
    "@earendil-works/pi-tui": "^0.79.4"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.79.0"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.4",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
